{
  "_meta": {
    "version": "2.0.0",
    "description": "Procedural quest templates for Canon Engine RPG",
    "note": "Each template is instantiated with state context; rewards scale with level"
  },
  "quest_templates": [
    {
      "id": "delivery",
      "type": "delivery",
      "title_template": "Deliver {item_name} to {destination}",
      "description_template": "{giver} needs a {item_name} delivered safely to {destination}. Time is of the essence.",
      "objectives_template": [
        {"text": "Obtain the {item_name} from {giver}", "target": "obtain", "count": 1},
        {"text": "Deliver the {item_name} to {destination}", "target": "deliver", "count": 1}
      ],
      "reward_base": {"gold": 30, "xp": 50, "item": null},
      "expires_turns": 15,
      "variables": {
        "item_name": ["sealed package", "medicine crate", "diplomatic letter", "rare gemstone", "ancient scroll"],
        "destination": ["the eastern village", "the mountain outpost", "the port town", "the scholar's tower", "the frontier fort"]
      }
    },
    {
      "id": "hunt",
      "type": "hunt",
      "title_template": "Hunt the {enemy_name}",
      "description_template": "{enemy_name}s have been terrorizing the area. {giver} offers a bounty for their elimination.",
      "objectives_template": [
        {"text": "Slay {count} {enemy_name}(s)", "target": "kill", "count": "{count}"},
        {"text": "Report back to {giver}", "target": "return", "count": 1}
      ],
      "reward_base": {"gold": 50, "xp": 80, "item": null},
      "expires_turns": 20,
      "variables": {
        "enemy_name": ["wolf", "bandit", "goblin", "dire rat", "skeleton", "spider"],
        "count_min": 3,
        "count_max": 8
      }
    },
    {
      "id": "fetch",
      "type": "fetch",
      "title_template": "Retrieve the {item_name}",
      "description_template": "{giver} needs {item_name} retrieved from {source}. It won't be easy to find.",
      "objectives_template": [
        {"text": "Travel to {source}", "target": "travel", "count": 1},
        {"text": "Find the {item_name}", "target": "retrieve", "count": 1},
        {"text": "Return the {item_name} to {giver}", "target": "return", "count": 1}
      ],
      "reward_base": {"gold": 40, "xp": 65, "item": null},
      "expires_turns": null,
      "variables": {
        "item_name": ["herb bundle", "stolen artifact", "family heirloom", "lost journal", "crystal shard"],
        "source": ["the old ruins", "the dark forest", "the abandoned mine", "the cave system", "the swamp"]
      }
    },
    {
      "id": "travel",
      "type": "travel",
      "title_template": "Journey to {destination}",
      "description_template": "{giver} asks you to travel to {destination} and deliver a message to {contact}.",
      "objectives_template": [
        {"text": "Travel to {destination}", "target": "travel", "count": 1},
        {"text": "Make contact with {contact}", "target": "contact", "count": 1},
        {"text": "Deliver the message", "target": "deliver_message", "count": 1}
      ],
      "reward_base": {"gold": 35, "xp": 55, "item": null},
      "expires_turns": 25,
      "variables": {
        "destination": ["the frontier settlement", "the hidden monastery", "the trading post", "the coastal village", "the mountain pass"],
        "contact": ["a hooded informant", "the local elder", "a trusted ally", "a foreign dignitary", "an old friend"]
      }
    },
    {
      "id": "investigation",
      "type": "investigation",
      "title_template": "Investigate {mystery}",
      "description_template": "Strange things are happening around {location}. {giver} wants answers.",
      "objectives_template": [
        {"text": "Gather clues about {mystery}", "target": "gather_clues", "count": 3},
        {"text": "Interview witnesses", "target": "interview", "count": 2},
        {"text": "Confront the source of {mystery}", "target": "confront", "count": 1}
      ],
      "reward_base": {"gold": 60, "xp": 100, "item": null},
      "expires_turns": null,
      "variables": {
        "mystery": ["the disappearances", "the strange lights", "the cursed well", "the missing shipments", "the haunted manor"],
        "location": ["the old quarter", "the outskirts", "the market district", "the temple grounds", "the harbor"]
      }
    }
  ]
}
