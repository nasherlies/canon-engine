# ─── Canon Engine Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your values.

# LLM Provider settings
CANON_LLM_PROVIDER=openai
CANON_LLM_MODEL=gpt-4o
CANON_LLM_API_KEY=sk-your-api-key-here

# Project root (auto-detected if not set)
# CANON_PROJECT_ROOT=/path/to/canon-engine

# Logging (DEBUG, INFO, WARNING, ERROR)
CANON_LOG_LEVEL=INFO

# Autosave ("1" = enabled, "0" = disabled)
CANON_AUTOSAVE=1

# API server auth (leave empty for open access in dev)
ADMIN_PASSWORD=your-admin-password

# API server bind address
# CANON_API_HOST=127.0.0.1
# CANON_API_PORT=8787
